{
  "mcpServers": {
    "grafana": {
      "command": "/home/bruno/.local/bin/uvx",
      "args": ["mcp-grafana"],
      "env": {
        "GRAFANA_URL": "http://localhost:53000",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "${GRAFANA_MCP_TOKEN}"
      }
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://claude_ro:${CLAUDE_MCP_RO_PASSWORD}@localhost:55432/recess"
      ]
    },
    "redis": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-redis",
        "redis://:${REDIS_PASSWORD}@localhost:56379"
      ]
    },
    "recess-game": {
      "command": "npx",
      "args": ["--yes", "tsx", "./tools/mcp-game/src/index.ts"],
      "env": {
        "RECESS_BASE_URL": "http://localhost"
      }
    }
  }
}
