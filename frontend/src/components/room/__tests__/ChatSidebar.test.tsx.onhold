describe('unknown command', () => {
  it('shows error message for unknown command', async () => {
    const user = userEvent.setup()
    renderSidebar()
    await user.type(screen.getByPlaceholderText('Message or /command...'), '/fly{Enter}')
    expect(screen.getByText(/Unknown command/)).toBeInTheDocument()
  })

  it('suggests /help in the error message', async () => {
    const user = userEvent.setup()
    renderSidebar()
    await user.type(screen.getByPlaceholderText('Message or /command...'), '/fly{Enter}')
    expect(screen.getByText(/Type \/help/)).toBeInTheDocument()
  })
})

// ---------------------------------------------------------------------------
// System messages
// ---------------------------------------------------------------------------

describe('system messages', () => {
  it('renders multiline system messages as separate lines', async () => {
    const user = userEvent.setup()
    renderSidebar()
    await user.type(screen.getByPlaceholderText('Message or /command...'), '/help{Enter}')
    // Help text has 7 lines — each rendered as a separate span.
    const lines = screen.getAllByText(/^\/.+—/)
    expect(lines.length).toBeGreaterThanOrEqual(6)
  })
})