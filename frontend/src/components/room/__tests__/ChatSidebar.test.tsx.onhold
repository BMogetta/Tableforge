import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest'
import { render, screen, act } from '@testing-library/react'
import userEvent from '@testing-library/user-event'
import { QueryClient, QueryClientProvider } from '@tanstack/react-query'
import { useAppStore } from '../../../store'
import { ToastProvider } from '../../ui/Toast'
import { ChatSidebar } from '../ChatSidebar'
import type { RoomMessage, RoomViewPlayer } from '../../../api'

// ---------------------------------------------------------------------------
// Mocks
// ---------------------------------------------------------------------------

vi.mock('../../../api', async (importOriginal) => {
  const actual = await importOriginal<typeof import('../../../api')>()
  return {
    ...actual,
    rooms: {
      ...actual.rooms,
      messages: vi.fn().mockResolvedValue([]),
      sendMessage: vi.fn().mockResolvedValue({ message_id: 'new-1', content: 'hello' }),
    },
    mutes: {
      list:   vi.fn().mockResolvedValue([]),
      mute:   vi.fn().mockResolvedValue(undefined),
      unmute: vi.fn().mockResolvedValue(undefined),
    },
  }
})

// ---------------------------------------------------------------------------
// Fixtures
// ---------------------------------------------------------------------------

const PLAYER_SELF: RoomViewPlayer = { id: 'self', username: 'alice', avatar_url: undefined, is_bot: false, role: 'player', seat: 0, created_at: Date.now().toString(), joined_at: Date.now().toString() }
const PLAYER_BOB: RoomViewPlayer  = { id: 'bob',  username: 'bob',   avatar_url: undefined, is_bot: false, role: 'player', seat: 0, created_at: (Date.now() + 100).toString(), joined_at: (Date.now() + 100).toString() }

function makeMessage(overrides: Partial<RoomMessage> = {}): RoomMessage {
  return {
    message_id: `msg-${Math.random()}`,
    room_id:    'room-1',
    player_id:  'bob',
    content:    'hello',
    hidden:     false,
    reported:   false,
    timestamp:  new Date().toISOString(),
    ...overrides,
  }
}

// ---------------------------------------------------------------------------
// Render helper
// ---------------------------------------------------------------------------

interface RenderOptions {
  open?:        boolean
  mutedIds?:    Set<string>
  muteAll?:     boolean
  roomPlayers?: RoomViewPlayer[]
  messages?:    RoomMessage[]
}

function renderSidebar(opts: RenderOptions = {}) {
  const {
    open        = true,
    mutedIds    = new Set<string>(),
    muteAll     = false,
    roomPlayers = [PLAYER_SELF, PLAYER_BOB],
  } = opts

  useAppStore.setState({
    player: { id: 'self', username: 'alice', role: 'player', is_bot: false, created_at: '' },
    socket: null,
  })

  const qc = new QueryClient({ defaultOptions: { queries: { retry: false } } })
  if (opts.messages) {
    qc.setQueryData(['roomMessages', 'room-1'], opts.messages)
  }

  const onToggle    = vi.fn()
  const onMute      = vi.fn()
  const onUnmute    = vi.fn()
  const onMuteAll   = vi.fn()
  const onUnmuteAll = vi.fn()

  const result = render(
    <QueryClientProvider client={qc}>
      <ToastProvider>
        <ChatSidebar
          roomId="room-1"
          open={open}
          onToggle={onToggle}
          mutedIds={mutedIds}
          muteAll={muteAll}
          onMute={onMute}
          onUnmute={onUnmute}
          onMuteAll={onMuteAll}
          onUnmuteAll={onUnmuteAll}
          roomPlayers={roomPlayers}
        />
      </ToastProvider>
    </QueryClientProvider>
  )

  return { ...result, onToggle, onMute, onUnmute, onMuteAll, onUnmuteAll }
}

// ---------------------------------------------------------------------------
// Setup / teardown
// ---------------------------------------------------------------------------

beforeEach(() => { vi.clearAllMocks() })
afterEach(()  => { vi.clearAllMocks() })

// ---------------------------------------------------------------------------
// Rendering
// ---------------------------------------------------------------------------

describe('rendering', () => {
  it('shows only toggle button when closed', () => {
    renderSidebar({ open: false })
    expect(screen.queryByPlaceholderText('Message or /command...')).toBeNull()
    expect(screen.queryByText('Room Chat')).toBeNull()
  })

  it('shows header and input when open', () => {
    renderSidebar()
    expect(screen.getByText('Room Chat')).toBeInTheDocument()
    expect(screen.getByPlaceholderText('Message or /command...')).toBeInTheDocument()
  })

  it('calls onToggle when toggle button is clicked', async () => {
    const user = userEvent.setup()
    const { onToggle } = renderSidebar()
    await user.click(screen.getByTitle('Hide chat'))
    expect(onToggle).toHaveBeenCalledOnce()
  })

  it('shows empty state when there are no messages', () => {
    renderSidebar({ messages: [] })
    expect(screen.getByText(/No messages yet/)).toBeInTheDocument()
  })

  it('renders message content', () => {
    renderSidebar({ messages: [makeMessage({ content: 'hey there' })] })
    expect(screen.getByText('hey there')).toBeInTheDocument()
  })

  it('shows sender username for messages from others', () => {
    renderSidebar({ messages: [makeMessage({ player_id: 'bob', content: 'hi' })] })
    expect(screen.getByText('bob')).toBeInTheDocument()
  })

  it('does not show username for own messages', () => {
    renderSidebar({ messages: [makeMessage({ player_id: 'self', content: 'mine' })] })
    // 'alice' should not appear as a sender label above the bubble.
    expect(screen.queryByText('alice')).toBeNull()
  })

  it('does not render hidden messages', () => {
    renderSidebar({ messages: [makeMessage({ content: 'secret', hidden: true })] })
    expect(screen.queryByText('secret')).toBeNull()
  })

  it('send button is disabled when draft is empty', () => {
    renderSidebar()
    expect(screen.getByTitle('Send')).toBeDisabled()
  })

  it('send button is enabled when draft has content', async () => {
    const user = userEvent.setup()
    renderSidebar()
    await user.type(screen.getByPlaceholderText('Message or /command...'), 'hello')
    expect(screen.getByTitle('Send')).not.toBeDisabled()
  })
})

// ---------------------------------------------------------------------------
// Message filtering
// ---------------------------------------------------------------------------

describe('message filtering', () => {
  it('muteAll hides messages from other players', () => {
    renderSidebar({
      muteAll:  true,
      messages: [makeMessage({ player_id: 'bob', content: 'from bob' })],
    })
    expect(screen.queryByText('from bob')).toBeNull()
  })

  it('muteAll does not hide own messages', () => {
    renderSidebar({
      muteAll:  true,
      messages: [makeMessage({ player_id: 'self', content: 'from me' })],
    })
    expect(screen.getByText('from me')).toBeInTheDocument()
  })

  it('mutedIds hides messages from a muted player', () => {
    renderSidebar({
      mutedIds: new Set(['bob']),
      messages: [makeMessage({ player_id: 'bob', content: 'muted msg' })],
    })
    expect(screen.queryByText('muted msg')).toBeNull()
  })

  it('mutedIds does not hide own messages even if self is in the set', () => {
    renderSidebar({
      mutedIds: new Set(['self']),
      messages: [makeMessage({ player_id: 'self', content: 'own msg' })],
    })
    expect(screen.getByText('own msg')).toBeInTheDocument()
  })

  it('visible message count badge reflects filtered results', () => {
    renderSidebar({
      muteAll:  true,
      messages: [
        makeMessage({ player_id: 'bob',  content: 'hidden' }),
        makeMessage({ player_id: 'self', content: 'visible' }),
      ],
    })
    // Only own message passes the filter — count should be 1.
    expect(screen.getByText('1')).toBeInTheDocument()
  })
})

// ---------------------------------------------------------------------------
// Send message
// ---------------------------------------------------------------------------

describe('send message', () => {
  it('sends message on Enter key', async () => {
    const user = userEvent.setup()
    const { rooms } = await import('../../../api')
    renderSidebar()
    await user.type(screen.getByPlaceholderText('Message or /command...'), 'hello world{Enter}')
    expect(rooms.sendMessage).toHaveBeenCalledWith('room-1', 'self', 'hello world')
  })

  it('does not send slash commands as chat messages', async () => {
    const user = userEvent.setup()
    const { rooms } = await import('../../../api')
    renderSidebar()
    await user.type(screen.getByPlaceholderText('Message or /command...'), '/help{Enter}')
    expect(rooms.sendMessage).not.toHaveBeenCalled()
  })
})

// ---------------------------------------------------------------------------
// /help
// ---------------------------------------------------------------------------

describe('/help', () => {
  it('shows help text as a system message', async () => {
    const user = userEvent.setup()
    renderSidebar()
    await user.type(screen.getByPlaceholderText('Message or /command...'), '/help{Enter}')
    expect(screen.getByText(/\/mute <username>/)).toBeInTheDocument()
  })
})

// ---------------------------------------------------------------------------
// /mute
// ---------------------------------------------------------------------------

describe('/mute', () => {
  it('calls onMute with the resolved player id', async () => {
    const user = userEvent.setup()
    const { onMute } = renderSidebar({ roomPlayers: [PLAYER_SELF, PLAYER_BOB] })
    await user.type(screen.getByPlaceholderText('Message or /command...'), '/mute bob{Enter}')
    expect(onMute).toHaveBeenCalledWith('bob')
  })

  it('shows a system confirmation message', async () => {
    const user = userEvent.setup()
    renderSidebar({ roomPlayers: [PLAYER_SELF, PLAYER_BOB] })
    await user.type(screen.getByPlaceholderText('Message or /command...'), '/mute bob{Enter}')
    expect(screen.getByText(/Muted bob/)).toBeInTheDocument()
  })

  it('shows error when username is missing', async () => {
    const user = userEvent.setup()
    renderSidebar()
    await user.type(screen.getByPlaceholderText('Message or /command...'), '/mute{Enter}')
    expect(screen.getByText(/Usage: \/mute/)).toBeInTheDocument()
  })

  it('shows error when player is not in the room', async () => {
    const user = userEvent.setup()
    renderSidebar()
    await user.type(screen.getByPlaceholderText('Message or /command...'), '/mute ghost{Enter}')
    expect(screen.getByText(/not found/)).toBeInTheDocument()
  })

  it('shows error when trying to mute self', async () => {
    const user = userEvent.setup()
    renderSidebar({ roomPlayers: [PLAYER_SELF, PLAYER_BOB] })
    await user.type(screen.getByPlaceholderText('Message or /command...'), '/mute alice{Enter}')
    expect(screen.getByText(/cannot mute yourself/i)).toBeInTheDocument()
  })

  it('is case-insensitive for username matching', async () => {
    const user = userEvent.setup()
    const { onMute } = renderSidebar({ roomPlayers: [PLAYER_SELF, PLAYER_BOB] })
    await user.type(screen.getByPlaceholderText('Message or /command...'), '/mute BOB{Enter}')
    expect(onMute).toHaveBeenCalledWith('bob')
  })
})

