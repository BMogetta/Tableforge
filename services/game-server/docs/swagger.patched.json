    "/sessions/{sessionID}/surrender": {
      "post": {
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "tags": [
          "sessions"
        ],
        "summary": "Surrender a game",
        "parameters": [
          {
            "type": "string",
            "description": "Session UUID",
            "name": "sessionID",
            "in": "path",
            "required": true
          },
          {
            "description": "Player ID",
            "name": "body",
            "in": "body",
            "required": true,
