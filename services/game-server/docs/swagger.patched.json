        ],
        "produces": [
          "application/json"
        ],
        "tags": [
          "sessions"
        ],
        "summary": "Vote for rematch",
        "parameters": [
          {
            "type": "string",
            "description": "Session UUID",
            "name": "sessionID",
            "in": "path",
            "required": true
          },
          {
            "description": "Player ID",
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/rematchRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/RematchResponse"
            }
          },
          "404": {
            "description": "Not Found",
            "schema": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "/sessions/{sessionID}/resume": {
      "post": {
        "produces": [
          "application/json"
        ],
        "tags": [
          "sessions"
        ],
        "summary": "Vote to resume",
        "parameters": [
          {
            "type": "string",
            "description": "Session UUID",
            "name": "sessionID",
            "in": "path",
