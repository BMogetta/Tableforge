  "definitions": {
    "EndedBy": {
      "type": "string",
      "enum": [
        "win",
        "draw",
        "forfeit",
        "timeout",
        "ready_timeout",
        "suspended"
      ],
      "x-enum-varnames": [
        "EndedByNormal",
        "EndedByDraw",
        "EndedByForfeit",
        "EndedByTimeout",
        "EndedByReadyTimeout",
        "EndedBySuspended"
      ]
    },
    "GameResult": {
      "type": "object",
      "properties": {
        "created_at": {
          "type": "string"
        },
        "duration_secs": {
          "type": "integer"
        },
        "ended_by": {
          "$ref": "#/definitions/EndedBy"
        },
        "game_id": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "is_draw": {
          "type": "boolean"
        },
        "session_id": {
          "type": "string"
        },
        "winner_id": {
          "type": "string"
        }
      }
    },
    "GameSessionDTO": {
      "type": "object",
      "properties": {
        "finished_at": {
          "type": "string"
        },
        "game_id": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "last_move_at": {
          "type": "string"
        },
        "mode": {
          "type": "string"
        },
        "move_count": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "ready_players": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "room_id": {
          "type": "string"
        },
        "started_at": {
          "type": "string"
        },
        "suspend_count": {
          "type": "integer"
        },
        "suspended_at": {
          "type": "string"
        },
        "suspended_reason": {
          "type": "string"
        },
        "turn_timeout_secs": {
          "type": "integer"
        }
      },
      "required": [
        "id",
        "game_id",
        "room_id",
        "name",
        "mode",
        "move_count",
        "suspend_count",
        "pause_votes",
        "resume_votes",
        "ready_players",
        "turn_timeout_secs"
      ]
    },
    "MoveDTO": {
      "type": "object",
      "properties": {
        "applied_at": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "move_number": {
          "type": "integer"
        },
        "payload": {},
        "player_id": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "state_after": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "session_id",
        "player_id",
        "move_number",
        "payload",
        "applied_at"
      ]
    },
    "MoveResponse": {
      "type": "object",
      "properties": {
        "is_over": {
          "type": "boolean"
        },
        "result": {
          "$ref": "#/definitions/Result"
        },
        "session": {
          "$ref": "#/definitions/GameSessionDTO"
        },
        "state": {}
      },
      "required": [
        "session",
        "state",
        "is_over"
      ]
    },
    "PauseVoteResult": {
      "type": "object",
      "properties": {
        "all_voted": {
          "description": "AllVoted is true when consensus was reached and the session state changed.",
          "type": "boolean"
        },
        "required": {
          "description": "Required is the number of human participants who must vote.",
          "type": "integer"
        },
        "votes": {
          "description": "Votes is the number of players that have voted so far.",
          "type": "integer"
        }
      },
      "required": [
        "all_voted",
        "votes",
        "required"
      ]
    },
    "ReadyVoteResult": {
      "type": "object",
      "properties": {
        "all_ready": {
          "type": "boolean"
        },
        "ready_players": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required": {
          "type": "integer"
        }
      },
      "required": [
        "all_ready",
        "ready_players",
        "required"
      ]
    },
    "RematchResponse": {
      "type": "object",
      "properties": {
        "total_players": {
          "type": "integer"
        },
        "votes": {
          "type": "integer"
        }
      },
      "required": [
        "votes",
        "total_players"
      ]
    },
    "Result": {
      "type": "object",
      "properties": {
        "status": {
          "$ref": "#/definitions/ResultStatus"
        },
        "winner_id": {
          "type": "string"
        }
      }
    },
    "ResultStatus": {
      "type": "string",
      "enum": [
        "win",
        "draw"
      ],
      "x-enum-varnames": [
        "ResultWin",
        "ResultDraw"
      ]
    },
    "SessionEventDTO": {
      "type": "object",
      "properties": {
        "event_type": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "occurred_at": {
          "type": "string"
        },
        "payload": {},
        "player_id": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "session_id",
        "player_id",
        "event_type",
        "payload",
        "occurred_at"
      ]
    },
    "SessionResponse": {
      "type": "object",
      "properties": {
        "result": {
          "$ref": "#/definitions/GameResult"
        },
        "session": {
          "$ref": "#/definitions/GameSessionDTO"
        },
        "state": {}
      },
      "required": [
        "session",
        "state"
      ]
    },
    "moveRequest": {
      "type": "object",
      "properties": {
        "payload": {
          "type": "object",
          "additionalProperties": {}
        },
        "player_id": {
          "type": "string"
        }
      }
    },
    "rematchRequest": {
      "type": "object",
      "properties": {
        "player_id": {
          "type": "string"
        }
      }
    },
    "surrenderRequest": {
      "type": "object",
      "properties": {
        "player_id": {
          "type": "string"
        }
      }
    }
  }
}
