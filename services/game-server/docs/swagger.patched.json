        ],
        "summary": "Vote ready",
        "parameters": [
          {
            "type": "string",
            "description": "Session UUID",
            "name": "sessionID",
            "in": "path",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/ReadyVoteResult"
            }
          },
          "404": {
            "description": "Not Found",
            "schema": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      }
    },
