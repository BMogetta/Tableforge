{
  "swagger": "2.0",
  "info": {
    "title": "Recess API",
    "contact": {},
    "version": "1.0"
  },
  "host": "localhost",
  "basePath": "/api/v1",
  "paths": {
    "/sessions/{sessionID}": {
      "get": {
        "produces": [
          "application/json"
        ],
        "tags": [
          "sessions"
        ],
        "summary": "Get game session",
        "parameters": [
          {
            "type": "string",
            "description": "Session UUID",
            "name": "sessionID",
            "in": "path",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/SessionResponse"
            }
          },
          "404": {
            "description": "Not Found",
            "schema": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "/sessions/{sessionID}/events": {
      "get": {
        "produces": [
          "application/json"
        ],
        "tags": [
          "sessions"
        ],
        "summary": "Get session events",
        "parameters": [
          {
            "type": "string",
            "description": "Session UUID",
            "name": "sessionID",
            "in": "path",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/SessionEventDTO"
              }
            }
          },
          "404": {
            "description": "Not Found",
            "schema": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "/sessions/{sessionID}/history": {
      "get": {
        "produces": [
          "application/json"
        ],
        "tags": [
          "sessions"
        ],
        "summary": "Get session history",
        "parameters": [
          {
            "type": "string",
            "description": "Session UUID",
            "name": "sessionID",
            "in": "path",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/MoveDTO"
              }
            }
          },
          "404": {
            "description": "Not Found",
            "schema": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "/sessions/{sessionID}/move": {
      "post": {
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "tags": [
          "sessions"
        ],
        "summary": "Apply a move",
        "parameters": [
          {
            "type": "string",
            "description": "Session UUID",
            "name": "sessionID",
            "in": "path",
            "required": true
          },
          {
            "description": "Move payload",
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/moveRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/MoveResponse"
            }
          },
          "400": {
            "description": "Bad Request",
            "schema": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "404": {
            "description": "Not Found",
            "schema": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "409": {
            "description": "Conflict",
            "schema": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      }
    },
