{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "defs/achievement_definition.json",
  "title": "AchievementDefinition",
  "type": "object",
  "properties": {
    "key": { "type": "string", "minLength": 1 },
    "name_key": { "type": "string", "minLength": 1 },
    "description_key": { "type": "string" },
    "game_id": { "type": "string" },
    "type": { "type": "string", "enum": ["flat", "tiered"] },
    "tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "threshold": { "type": "integer", "minimum": 1 },
          "name_key": { "type": "string", "minLength": 1 },
          "description_key": { "type": "string", "minLength": 1 }
        },
        "required": ["threshold", "name_key", "description_key"]
      }
    }
  },
  "required": ["key", "name_key", "game_id", "type", "tiers"]
}
