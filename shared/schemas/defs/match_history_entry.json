{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "defs/match_history_entry.json",
  "title": "MatchHistoryEntry",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "session_id": { "type": "string" },
    "game_id": { "type": "string" },
    "outcome": {
      "type": "string",
      "enum": ["win", "loss", "draw", "forfeit"]
    },
    "ended_by": {
      "type": "string",
      "enum": ["win", "draw", "forfeit", "timeout", "ready_timeout", "suspended"]
    },
    "duration_secs": { "type": "integer" },
    "created_at": { "type": "string", "format": "date-time" },
    "opponent_id": { "type": "string" },
    "opponent_username": { "type": "string" },
    "opponent_is_bot": { "type": "boolean" },
    "opponent_bot_profile": {
      "type": "string",
      "enum": ["easy", "medium", "hard", "aggressive"]
    }
  },
  "required": ["id", "session_id", "game_id", "outcome", "ended_by", "created_at"]
}
