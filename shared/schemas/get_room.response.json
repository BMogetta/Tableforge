{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "get_room.response.json",
  "title": "GetRoomResponse",
  "type": "object",
  "properties": {
    "room": { "$ref": "defs/room.json" },
    "players": {
      "type": "array",
      "items": { "$ref": "defs/room_player.json" }
    },
    "settings": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "required": ["room", "players", "settings"]
}
