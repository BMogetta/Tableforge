# ── GitHub OAuth ────────────────────────────────────────────────────────────
# Create an OAuth App at github.com/settings/developers
# Callback URL: http://localhost/auth/github/callback (dev)
#               https://yourdomain.com/auth/github/callback (prod)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Environment ─────────────────────────────────────────────────────────────
# "development" → HTTP cookies (no Secure flag)
# "production"  → HTTPS-only cookies (Secure flag enabled)
ENV=development

# ── Seed ────────────────────────────────────────────────────────────────────
# Email to whitelist on first run if allowed_emails is empty.
# Must match the primary verified email on your GitHub account.
OWNER_EMAIL=

# ── Domain (prod only) ──────────────────────────────────────────────────────
# Your domain pointed to Cloudflare, e.g. recess.example.com
DOMAIN=

# ── Cloudflare Tunnel (prod only) ───────────────────────────────────────────
# Get this token from: dash.cloudflare.com → Zero Trust → Tunnels → Create tunnel
# The tunnel should point to http://caddy:80
CLOUDFLARE_TUNNEL_TOKEN=

# ── Grafana ─────────────────────────────────────────────────────────────────
# Generate hash with: echo $(htpasswd -nB admin) | sed -e 's/\$/\$\$/g't
GRAFANA_BASICAUTH_HASH=
# Generate with: openssl rand -base64 32
# Unleash (feature flags) — accessible via Traefik
# Dev: unleash.localhost / Prod: unleash.yourdomain.com
UNLEASH_HOST=unleash.localhost

GRAFANA_ADMIN_PASSWORD=
# MCP token for Claude Code ↔ Grafana integration (mcp-grafana).
# Create at: http://grafana.localhost → Administration → Service Accounts
#   1. Add Service Account (e.g. "claude-mcp"), role: Viewer
#   2. Generate token → copy here
# Viewer role grants: dashboard read, Loki queries, folder navigation.
GRAFANA_MCP_TOKEN=

# ── WebSocket ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for ws-gateway CORS.
# Default: http://localhost (dev). Set to your domain in production.
ALLOWED_ORIGINS=http://localhost

# ── Redis ────────────────────────────────────────────────────────────────────
# Password for Redis authentication. Default: recess (dev only!)
# Generate with: openssl rand -hex 32
REDIS_PASSWORD=recess

# ── Database ─────────────────────────────────────────────────────────────────
# Superuser (admin only, not used by application services)
POSTGRES_PASSWORD=recess
# Application user (owns the recess database)
RECESS_DB_PASSWORD=recess
# Unleash user (owns the unleash database, feature flags)
UNLEASH_DB_PASSWORD=unleash
# Read-only user for Claude MCP postgres integration
CLAUDE_MCP_RO_PASSWORD=claude_ro

# In production, set DB_HOST=pgbouncer to route through connection pooling.
# In development, leave unset (defaults to postgres for direct connection).
DB_HOST=postgres

# ── Ranked matchmaking ──────────────────────────────────────────────────────
# Game ID used for ranked rooms created by match-service. Defaults to
# queue.DefaultRankedGameID if unset.
RANKED_GAME_ID=rootaccess

# ── Ranked bot backfill (match-service) ─────────────────────────────────────
# When enabled, match-service injects a bot into the ranked queue if a
# lone human has been waiting past BACKFILL_THRESHOLD_SECS. The activation
# signal is published on Redis channel bot.activate; bot-runner subscribes
# in --mode=backfill.
#
# BACKFILL_ENABLED     — toggle ("true" | "false"), off by default.
# BACKFILL_THRESHOLD_SECS — wait time before a lone human triggers backfill.
# BACKFILL_MAX_ACTIVE  — cap on simultaneously-active bots across games.
BACKFILL_ENABLED=false
BACKFILL_THRESHOLD_SECS=15
BACKFILL_MAX_ACTIVE=3

# ── Bot service auth (auth-service + bot-runner) ────────────────────────────
# Shared secret exchanged via X-Bot-Secret on POST /auth/bot-login.
# Leave empty to disable the endpoint (it returns 401 to every request,
# which is the safe default for environments that do not run bots).
# Generate with: openssl rand -hex 32
BOT_SERVICE_SECRET=