# ── Environment ─────────────────────────────────────────────────────────────
# "development" → HTTP cookies (no Secure flag)
# "production"  → HTTPS-only cookies (Secure flag enabled)
ENV=development

# ── Domain ──────────────────────────────────────────────────────────────────
# Base host for the app. Dev: "localhost". Prod: your app hostname, e.g.
# "recess.bmogetta.com". All derived URLs below interpolate ${DOMAIN}.
DOMAIN=localhost

# "http" in dev, "https" in prod (Cloudflare Tunnel terminates TLS at the edge).
APP_SCHEME=http

# ── GitHub OAuth ────────────────────────────────────────────────────────────
# Create an OAuth App at github.com/settings/developers
# Callback URL: ${APP_SCHEME}://${DOMAIN}/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Seed ────────────────────────────────────────────────────────────────────
# Email to whitelist on first run if allowed_emails is empty.
# Must match the primary verified email on your GitHub account.
OWNER_EMAIL=

# ── Cloudflare Tunnel (prod only) ───────────────────────────────────────────
# Get this token from: dash.cloudflare.com → Zero Trust → Networks → Tunnels.
# In the tunnel's Public Hostname config, point the hostname to
# http://traefik:80 (resolvable because cloudflared shares app_network).
# Required by `make up-prod` — the Makefile preflight fails fast if empty.
CLOUDFLARE_TUNNEL_TOKEN=

# ── Derived hosts ───────────────────────────────────────────────────────────
# These expand from ${DOMAIN} above. Override only if you need a different
# subdomain scheme.
UNLEASH_HOST=unleash.${DOMAIN}
GRAFANA_HOST=grafana.${DOMAIN}

# ── Grafana ─────────────────────────────────────────────────────────────────
# Grafana's built-in admin — fallback for API access and service accounts.
# Generate with: openssl rand -base64 32. Leave unset in dev; Grafana falls
# back to its own default (admin) but login is disabled anyway by the knobs
# below, so it rarely matters.
GRAFANA_ADMIN_PASSWORD=
# MCP token for Claude Code ↔ Grafana integration (mcp-grafana).
# Create at: http://grafana.localhost → Administration → Service Accounts
#   1. Add Service Account (e.g. "claude-mcp"), role: Viewer
#   2. Generate token → copy here
# Viewer role grants: dashboard read, Loki queries, folder navigation.
GRAFANA_MCP_TOKEN=
# Grafana auth overrides. Dev defaults skip login entirely — you land on
# dashboards as Admin, no friction on a single-user local box. In prod these
# values are only safe if a gate (e.g. Cloudflare Access) sits in front of
# grafana.${DOMAIN}; without that, anonymous traffic gets Admin.
GRAFANA_ANON_ENABLED=true
GRAFANA_ANON_ROLE=Admin
GRAFANA_DISABLE_LOGIN=true

# ── Unleash ─────────────────────────────────────────────────────────────────
# Unleash runs with AUTH_TYPE=none — no login screen, every request gets a
# synthetic admin user. Only safe because the service is not directly exposed
# (traefik + cloudflare tunnel is the only public path). If UNLEASH_HOST ever
# becomes reachable from untrusted networks, switch to AUTH_TYPE=open-source
# and reintroduce UNLEASH_ADMIN_USERNAME / UNLEASH_ADMIN_PASSWORD.
#
# Service-side SDK config. Backend services (Go) call Unleash directly on the
# internal docker network; frontend uses the proxy endpoint via traefik.
UNLEASH_URL=http://unleash:4242/api
UNLEASH_API_TOKEN=*:*.unleash-insecure-api-token
UNLEASH_ENV=development

# ── WebSocket ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for ws-gateway CORS. Derived from
# ${APP_SCHEME} + ${DOMAIN}. Override if you need multiple origins.
ALLOWED_ORIGINS=${APP_SCHEME}://${DOMAIN}

# ── Redis ────────────────────────────────────────────────────────────────────
# Password for Redis authentication. Default: recess (dev only!)
# Generate with: openssl rand -hex 32
REDIS_PASSWORD=recess

# ── Database ─────────────────────────────────────────────────────────────────
# Superuser (admin only, not used by application services)
POSTGRES_PASSWORD=recess
# Application user (owns the recess database)
RECESS_DB_PASSWORD=recess
# Unleash user (owns the unleash database, feature flags)
UNLEASH_DB_PASSWORD=unleash
# Read-only user for Claude MCP postgres integration
CLAUDE_MCP_RO_PASSWORD=claude_ro

# In production, set DB_HOST=pgbouncer to route through connection pooling.
# In development, leave unset (defaults to postgres for direct connection).
DB_HOST=postgres

# ── Ranked matchmaking ──────────────────────────────────────────────────────
# Game ID used for ranked rooms created by match-service. Defaults to
# queue.DefaultRankedGameID if unset.
RANKED_GAME_ID=rootaccess

# ── Ranked bot backfill (match-service) ─────────────────────────────────────
# When enabled, match-service injects a bot into the ranked queue if a
# lone human has been waiting past BACKFILL_THRESHOLD_SECS. The activation
# signal is published on Redis channel bot.activate; bot-runner subscribes
# in --mode=backfill.
#
# BACKFILL_ENABLED     — toggle ("true" | "false"), off by default.
# BACKFILL_THRESHOLD_SECS — wait time before a lone human triggers backfill.
# BACKFILL_MAX_ACTIVE  — cap on simultaneously-active bots across games.
BACKFILL_ENABLED=false
BACKFILL_THRESHOLD_SECS=15
BACKFILL_MAX_ACTIVE=3

# ── Bot service auth (auth-service + bot-runner) ────────────────────────────
# Shared secret exchanged via X-Bot-Secret on POST /auth/bot-login.
# Leave empty to disable the endpoint (it returns 401 to every request,
# which is the safe default for environments that do not run bots).
# Generate with: openssl rand -hex 32
BOT_SERVICE_SECRET=