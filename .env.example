# ── GitHub OAuth ────────────────────────────────────────────────────────────
# Create an OAuth App at github.com/settings/developers
# Callback URL: http://localhost:8080/auth/github/callback (dev)
#               https://yourdomain.com/auth/github/callback (prod)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Environment ─────────────────────────────────────────────────────────────
# "development" → HTTP cookies (no Secure flag)
# "production"  → HTTPS-only cookies (Secure flag enabled)
ENV=development

# ── Seed ────────────────────────────────────────────────────────────────────
# Email to whitelist on first run if allowed_emails is empty.
# Must match the primary verified email on your GitHub account.
OWNER_EMAIL=

# ── Domain (prod only) ──────────────────────────────────────────────────────
# Your domain pointed to Cloudflare, e.g. tableforge.example.com
DOMAIN=

# ── Cloudflare Tunnel (prod only) ───────────────────────────────────────────
# Get this token from: dash.cloudflare.com → Zero Trust → Tunnels → Create tunnel
# The tunnel should point to http://caddy:80
CLOUDFLARE_TUNNEL_TOKEN=