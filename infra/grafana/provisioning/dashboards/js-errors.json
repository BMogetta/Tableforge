{
  "uid": "recess-js-errors",
  "title": "Recess — JS Errors",
  "tags": ["recess", "frontend", "errors"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Error rate (per minute)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 16, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 15 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "loki" },
          "expr": "sum(count_over_time({service_name=\"recess-frontend\"} | severity_text=`ERROR` [1m]))",
          "legendFormat": "JS errors/min"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total errors (last 1h)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "loki" },
          "expr": "sum(count_over_time({service_name=\"recess-frontend\"} | severity_text=`ERROR` [1h]))",
          "legendFormat": "Errors (1h)"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error log stream",
      "type": "logs",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 10 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "uid": "loki" },
          "expr": "{service_name=\"recess-frontend\"} | severity_text=`ERROR`",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 4,
      "title": "Errors by type",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 7 },
      "targets": [
        {
          "datasource": { "uid": "loki" },
          "expr": "sum by (error_type) (count_over_time({service_name=\"recess-frontend\"} | severity_text=`ERROR` [1m]))",
          "legendFormat": "{{error_type}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "OTel collector — accepted vs refused log records",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 7 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(otelcol_receiver_accepted_log_records_total[1m])",
          "legendFormat": "accepted"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(otelcol_receiver_refused_log_records_total[1m])",
          "legendFormat": "refused"
        }
      ]
    }
  ],
  "schemaVersion": 38
}